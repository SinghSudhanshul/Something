# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# NEXUS Auth Service — Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

NODE_ENV=development
AUTH_PORT=3001
LOG_LEVEL=debug

# ── Database ────────────────────────────────────────
DATABASE_URL=postgres://nexus:nexus_dev_secret@localhost:5432/nexus_dev
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9092

# ── JWT ─────────────────────────────────────────────
JWT_ACCESS_SECRET=nexus_jwt_access_secret_change_this_in_production_minimum_32_chars
JWT_REFRESH_SECRET=nexus_jwt_refresh_secret_change_this_in_production_minimum_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY_DAYS=30

# ── Security ───────────────────────────────────────
BCRYPT_ROUNDS=12
ALLOWED_EMAIL_DOMAINS=srmist.edu.in,srm.edu.in,srmuniv.ac.in
AUTH_CORS_ORIGIN=http://localhost:3000

# ── AWS (used in production only) ──────────────────
AWS_REGION=ap-south-1
AWS_SES_FROM_EMAIL=no-reply@nexus.app
